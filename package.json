{
  "name": "relay",
  "version": "0.1.1-dev",
  "description": "A modern, open-source cross-platform device hub.",
  "main": "dist-electron/main.js",
  "author": "Relay Contributors",
  "homepage": "https://github.com/relay/relay",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "electron:build:main": "vite build --config vite.electron.main.config.ts",
    "electron:build:preload": "vite build --config vite.electron.config.ts",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && npm run electron:build:main && npm run electron:build:preload && electron .\"",
    "electron:pack": "npm run build && npm run electron:build:main && npm run electron:build:preload",
    "package:dev": "npm run electron:dev",
    "package:linux": "npm run electron:pack && electron-builder --linux deb",
    "package:win": "npm run electron:pack && electron-builder --win nsis",
    "package:web": "mkdir -p release && VITE_BASE_URL=/ vite build --outDir=release/web",
    "package:all": "npm run electron:pack && electron-builder --linux deb --win nsis",
    "cap:sync": "npx cap sync",
    "cap:build:android": "npm run build && npx cap sync && export JAVA_HOME=/mnt/HDD/jdk21/jdk-21.0.7+6 && export GRADLE_USER_HOME=/mnt/HDD/gradle-home && cd android && ./gradlew assembleDebug",
    "MI1": "concurrently -k \"vite\" \"wait-on tcp:5173 && npm run electron:build:main && npm run electron:build:preload && RELAY_INSTANCE_ID=mi_1 RELAY_DEVICE_NAME=Relay-Alpha electron .\"",
    "MI2": "wait-on tcp:5173 && RELAY_INSTANCE_ID=mi_2 RELAY_DEVICE_NAME=Relay-Beta electron .",
    "MI3": "wait-on tcp:5173 && RELAY_INSTANCE_ID=mi_3 RELAY_DEVICE_NAME=Relay-Gamma electron .",
    "MI4": "wait-on tcp:5173 && RELAY_INSTANCE_ID=mi_4 RELAY_DEVICE_NAME=Relay-Delta electron .",
    "MI5": "wait-on tcp:5173 && RELAY_INSTANCE_ID=mi_5 RELAY_DEVICE_NAME=Relay-Epsilon electron .",
    "MI6": "wait-on tcp:5173 && RELAY_INSTANCE_ID=mi_6 RELAY_DEVICE_NAME=Relay-Zeta electron ."
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/clipboard": "^8.0.1",
    "@capacitor/core": "^8.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "ws": "^8.18.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "^31.5.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.11",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "wait-on": "^7.2.0"
  }
}
